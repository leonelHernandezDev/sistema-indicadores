      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true
    }
  },
  "devDependencies": {
    "electron": "^39.1.1",
    "electron-builder": "^26.8.1"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "bootstrap": "^5.3.8",
    "bootstrap-icons": "^1.13.1",
    "chart.js": "^4.5.1",
    "jspdf": "^4.2.0",
    "jspdf-autotable": "^5.0.7",
    "sqlite3": "^5.1.7",
    "xlsx": "^0.18.5"
  }
}
