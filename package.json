{
  "name": "sistemaindicadores",
  "version": "1.0.0",
  "description": "Sistema de Control Académico TESCI",
  "main": "main.js",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "start": "electron .",
    "dist": "electron-builder"
  },
  "keywords": [],
  "author": "TESCI",
  "license": "ISC",
  "build": {
    "appId": "com.tesci.sistemaindicadores",
    "productName": "Sistema Indicadores TESCI",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": "nsis"
    },
    "nsis": {
